---
import { BASE_CONFIG, DEVELOPMENT } from '../config'
---

<footer>
  <span class="footer-copyright">© {BASE_CONFIG.create_time.split('-')[0]} Built with by {BASE_CONFIG.author}.</span>
  <nav class="footer-nav">
    <a href="https://icp.gov.moe/?keyword=20240146" target="_blank">萌ICP备20240146号</a>
    <a href="/rss.xml">RSS</a>
    <button id="theme-toggle" type="button" aria-label="切换主题">Auto</button>
    <a href="#">{DEVELOPMENT.VERSION}</a>
  </nav>
</footer>

<script>
  import { setupThemeToggle } from '../scripts/theme.js';
  setupThemeToggle(document.getElementById('theme-toggle'));
</script>

<style>
  footer {
    margin: 0;
    padding: 1rem 0 1.5rem 0;
    border-top: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-copyright {
    font-size: var(--text-description-fontsize);
    color: var(--text-description-color);
  }

  .footer-nav {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .footer-nav a,
  .footer-nav button {
    font-size: var(--text-description-fontsize);
    color: var(--text-description-color);
    text-decoration: none;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: inherit;
  }
</style>
